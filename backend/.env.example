# ========================
# DATABASE
# ========================
DATABASE_URL="postgresql://clinic_user:clinic_pass@localhost:5432/clinic_db"

# ========================
# JWT
# ========================
JWT_SECRET="your-super-secret-jwt-key-256-bits-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-256-bits-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ========================
# REDIS
# ========================
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# ========================
# AWS S3 / MinIO
# ========================
AWS_S3_BUCKET="clinic-files"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="sa-east-1"
# Para MinIO local, descomente:
# AWS_S3_ENDPOINT="http://localhost:9000"

# ========================
# SMTP / EMAIL
# ========================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@clinic.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Clínica Sistema <noreply@clinic.com>"

# ========================
# APP
# ========================
APP_PORT=3001
NODE_ENV="development"

# CORS - domínios permitidos separados por vírgula
ALLOWED_ORIGINS="http://localhost:3000"
