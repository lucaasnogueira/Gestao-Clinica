# =====================================
# FRONTEND — Next.js 14
# =====================================
# Copie este arquivo para .env.local antes de rodar

# URL da API NestJS (acessível pelo browser)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# URL da API NestJS (acessível pelo servidor Next.js — igual em dev, diferente em Docker)
API_URL=http://localhost:3001/api/v1

# Em Docker, use o nome do serviço:
# API_URL=http://api:3001/api/v1
